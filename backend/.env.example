# 火山引擎方舟(豆包大模型)配置
# 获取步骤:火山引擎控制台 → 方舟(Ark) → 开通豆包大模型
#   → 创建「在线推理接入点」(得到 ep-xxxxxxxx,或直接用模型名)
#   → 「API Key 管理」创建密钥
#
# 复制本文件为 .env 并填入真实值(.env 已被 .gitignore 忽略,不会提交)

ARK_API_KEY=
ARK_MODEL=                 # 接入点 ID(ep-xxxxxxxx)或模型名

# 推理模型(如 doubao-seed 系列)填 disabled 可关闭"思考"、解析提速 2~3 倍;
# 非推理模型(如 doubao-1.5 系列)留空即可
ARK_THINKING=disabled

# 生成式收尾(文生图):在方舟「开通管理」开通 Seedream 文生图模型,把模型 ID 填这里
# 例如 doubao-seedream-5-0-260128 之类(以你账号实际开通的为准);不填则 /api/generate 报配置错误
ARK_IMAGE_MODEL=

# ───────────────────────────────────────────────────────────
# 七牛云 AI 大模型推理(OpenAI 兼容)—— 云端语音识别 ASR
# 获取:七牛云控制台 → AI 大模型推理 → 创建 API Key(https://developer.qiniu.com/aitokenapi)
# 作用:配置后前端走云端识别(跨浏览器、内地可用,替代依赖 Google 的浏览器 Web Speech);
#       不配置则前端自动回退浏览器识别(Chrome / Edge),主分支照常可运行。
QINIU_AI_KEY=
# QINIU_ASR_WS=wss://api.qnaigc.com/v1/voice/asr   # 流式识别 WebSocket,一般不用改
# QINIU_ASR_MODEL=asr                              # ASR 模型名,以七牛云文档/控制台为准

# 可选(一般不用改):
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# PORT=8787
